GITHUB_REMOTE=https://github.com/Langenhorner001/ST-Co-BOT.git
GITHUB_BRANCH=main
GITHUB_FORCE_PUSH=false

EC2_HOST=1.2.3.4
EC2_USER=ubuntu
EC2_DEPLOY_PATH=/home/ubuntu/st-checker-bot
EC2_SERVICE=st-checker-bot
EC2_START_COMMAND=/home/ubuntu/st-checker-bot/venv/bin/python3 /home/ubuntu/st-checker-bot/main.py
EC2_SSH_KEY_PATH=C:/Users/Administrator/Desktop/ST-CO-BOT/ec2_key.pem

# Optional deploy control
# Comma-separated list of files or folders to sync to EC2.
# Example: DEPLOY_FILES=main.py,database.py,handlers,services
DEPLOY_FILES=

# Optional exclusions from the default deploy manifest.
# Example: DEPLOY_EXCLUDE=attached_assets,backups
DEPLOY_EXCLUDE=
DEPLOY_WATCH_INTERVAL=5

# BIN lookup via RapidAPI / bincheck.io
BINCHECK_API_BASE=https://bincheck.io/api/v2/bin/{bin}
BINCHECK_API_HOST=bin-ip-checker.p.rapidapi.com
BINCHECK_API_KEY=
